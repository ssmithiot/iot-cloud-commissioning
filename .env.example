# Deployment identity: development | staging | production. Shown on /health.
ENVIRONMENT=development
# Staging safety guard. Keep false in staging; when ENVIRONMENT=staging the app
# refuses to start if DATABASE_URL/SUPABASE_URL match known production values.
ALLOW_PRODUCTION_RESOURCES=false
# Comma-separated substrings identifying production resources (hosts, project refs).
PRODUCTION_RESOURCE_FINGERPRINTS=iot-cloud-api-dev.onrender.com
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
AUTO_CREATE_TABLES=false
GATEWAY_AUTH_PEPPER=<generate-a-long-random-server-side-pepper>
IOT_ADMIN_API_TOKEN=<generate-a-long-random-admin-api-token>
SUPABASE_JWT_SECRET=<supabase-project-jwt-secret>
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-public-key>
# Optional override. Defaults to ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
TUNNEL_REQUEST_TIMEOUT_SEC=900
# Optional. Trend samples older than this many days are pruned on successful uploads. Defaults to 90.
TREND_RETENTION_DAYS=90
# Optional. Heartbeat history rows older than this many days are pruned per gateway on heartbeat. Defaults to 30.
HEARTBEAT_RETENTION_DAYS=30
# Optional database pool controls (non-SQLite only). Confirm Supabase/Render
# connection limits for the selected plan before raising pool sizes.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# Optional. Minimum seconds between auth telemetry writes (0 = write every request). Defaults to 60.
AUTH_TELEMETRY_MIN_INTERVAL_SEC=60
# Optional. Claimed jobs older than this are requeued at the gateway's next poll (BACnet writes excluded). Defaults to 600.
JOB_CLAIM_TIMEOUT_SEC=600
# Optional. Fleet alerting: leave empty to run POST /api/admin/alerts/evaluate silently
# (groundwork mode). Paste a Slack/Teams incoming-webhook URL to deliver alerts.
ALERT_WEBHOOK_URL=
# Optional. Trend backlog alert threshold: oldest pending sample age, hours. Defaults to 6.
ALERT_TREND_BACKLOG_AGE_HOURS=6
# Optional. Max webhook deliveries per evaluation run. Defaults to 50.
ALERT_MAX_DELIVERIES_PER_RUN=50
CLOUD_API_HOST=0.0.0.0
CLOUD_API_PORT=8000
